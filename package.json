{
	"name": "tldraw-server",
	"type": "module",
	"version": "1.0.0",
	"license": "AGPL-3.0",
	"description": "tldraw backend",
	"author": "Schulcloud-Verbund",
	"private": true,
	"engines": {
		"npm": "11",
		"node": "24"
	},
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\"",
		"start": "nest start server",
		"start:server:dev": "nest start server --watch",
		"start:server:debug": "nest start server --debug --watch",
		"start:server:prod": "node dist/apps/tldraw-server.app.js",
		"start:worker:dev": "nest start worker --watch",
		"start:worker:debug": "nest start worker --debug --watch",
		"start:worker:prod": "node dist/apps/tldraw-worker.app.js",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"pregenerate-client:authorization-api": "rimraf ./src/infra/authorization-client/authorization-api-client",
		"generate-client:authorization-api": "openapi-generator-cli generate -c ./openapitools.json --generator-key authorization-api"
	},
	"overrides": {
		"multer": "2.2.0",
		"js-yaml": "4.2.0",
		"@typescript-eslint/parser": "$@typescript-eslint/parser"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.27",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.27",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.1.27",
		"@nestjs/swagger": "^11.4.4",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"ioredis": "^5.11.1",
		"lib0": "^0.2.117",
		"minio": "^8.0.7",
		"nest-winston": "^1.10.2",
		"passport": "^0.7.0",
		"passport-headerapikey": "^1.2.2",
		"prom-client": "^15.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.68.0",
		"winston": "^3.19.0",
		"y-protocols": "^1.0.7",
		"yjs": "^13.6.31"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@golevelup/ts-jest": "^3.0.0",
		"@nestjs/cli": "^11.0.23",
		"@nestjs/schematics": "^11.1.0",
		"@nestjs/testing": "^11.1.27",
		"@openapitools/openapi-generator-cli": "^2.39.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.12.2",
		"@types/passport": "^1.0.17",
		"@types/supertest": "^7.2.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^10.6.0",
		"eslint-plugin-jest": "^29.15.2",
		"fishery": "^2.4.0",
		"globals": "^17.7.0",
		"jest": "^30.4.2",
		"prettier": "^3.8.4",
		"redis-memory-server": "^0.17.0",
		"rimraf": "^6.1.3",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.11",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^6.0.3",
		"ws": "^8.21.0",
		"y-websocket": "^3.0.0"
	}
}
